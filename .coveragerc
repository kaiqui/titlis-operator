[run]
source = src
omit = 
    */tests/*
    */__pycache__/*
    */venv/*
    */site-packages/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    class .*Test.*
    @property
    @abstractmethod

[html]
directory = coverage_html_report